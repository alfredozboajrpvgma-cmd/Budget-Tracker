# Supabase (frontend + server)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# hCaptcha (login / sign up) — also add secret key in Supabase Dashboard → Auth → Bot and Abuse Protection
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# Push notification server
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Netlify Forms (support questions) — form is declared in index.html as "support-question"
# Submissions appear in Netlify Dashboard → Forms after deploy
